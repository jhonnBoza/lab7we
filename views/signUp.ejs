<!DOCTYPE html>
<html lang="es">
<head>
  <%- include('partials/head') %>
</head>
<body>
  <nav class="blue darken-3 brand-bar">
    <div class="nav-wrapper container">
      <span class="brand-logo">Lab JWT</span>
      <ul class="right hide-on-med-and-down">
        <li><a href="/signIn">Iniciar sesión</a></li>
      </ul>
    </div>
  </nav>

  <main>
    <div class="container">
      <div class="row">
        <div class="col s12 m10 offset-m1">
          <div class="card">
            <div class="card-content">
              <span class="card-title">Registro</span>
              <p class="grey-text">
                Contraseña: mínimo 8 caracteres, 1 mayúscula, 1 dígito y 1 carácter especial (# $ % &amp; * @).
              </p>
              <div id="msg" class="red-text text-darken-2" style="min-height:1.5rem"></div>
              <form id="form-signup">
                <div class="row">
                  <div class="input-field col s12 m6">
                    <input id="name" type="text" required />
                    <label for="name">Nombre</label>
                  </div>
                  <div class="input-field col s12 m6">
                    <input id="lastName" type="text" required />
                    <label for="lastName">Apellidos</label>
                  </div>
                  <div class="input-field col s12 m6">
                    <input id="phoneNumber" type="tel" required />
                    <label for="phoneNumber">Teléfono</label>
                  </div>
                  <div class="input-field col s12 m6">
                    <input id="birthdate" type="date" required />
                    <label for="birthdate" class="active">Fecha de nacimiento</label>
                  </div>
                  <div class="input-field col s12 m6">
                    <input id="email" type="email" class="validate" required autocomplete="username" />
                    <label for="email">Email</label>
                  </div>
                  <div class="input-field col s12 m6">
                    <input id="password" type="password" required autocomplete="new-password" />
                    <label for="password">Contraseña</label>
                  </div>
                </div>
                <button class="btn waves-effect waves-light blue darken-3" type="submit">
                  Registrarse <i class="material-icons right">person_add</i>
                </button>
              </form>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>

  <%- include('partials/scripts') %>
  <script>
    document.addEventListener('DOMContentLoaded', function () {
      M.updateTextFields();
      document.getElementById('form-signup').addEventListener('submit', async function (e) {
        e.preventDefault();
        var msg = document.getElementById('msg');
        msg.textContent = '';
        var payload = {
          name: document.getElementById('name').value.trim(),
          lastName: document.getElementById('lastName').value.trim(),
          phoneNumber: document.getElementById('phoneNumber').value.trim(),
          birthdate: document.getElementById('birthdate').value,
          email: document.getElementById('email').value.trim(),
          password: document.getElementById('password').value,
          roles: ['user']
        };
        try {
          var res = await fetch('/api/auth/signUp', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
          });
          var data = await res.json().catch(function () {
            return {};
          });
          if (!res.ok) {
            msg.textContent = data.message || 'No se pudo registrar';
            return;
          }
          window.location.href = '/signIn';
        } catch (err) {
          msg.textContent = err.message || 'Error de red';
        }
      });
    });
  </script>
</body>
</html>
