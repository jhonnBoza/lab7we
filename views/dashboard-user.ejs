<!DOCTYPE html>
<html lang="es">
<head>
  <%- include('partials/head') %>
</head>
<body>
  <nav class="blue darken-3 brand-bar">
    <div class="nav-wrapper container">
      <span class="brand-logo">Usuario</span>
      <ul class="right hide-on-med-and-down">
        <li><a href="/dashboard-user">Inicio</a></li>
        <li><a href="/profile">Mi cuenta</a></li>
        <li><a href="#" id="logout">Salir</a></li>
      </ul>
    </div>
  </nav>

  <main>
    <div class="container">
      <div class="card">
        <div class="card-content">
          <span class="card-title" id="welcome">Cargando…</span>
          <p>Bienvenido. Aquí están tus datos principales.</p>
          <ul class="collection" id="summary"></ul>
          <p>
            <a class="btn blue darken-3" href="/profile">Ir a mi perfil</a>
          </p>
        </div>
      </div>
    </div>
  </main>

  <%- include('partials/scripts') %>
  <script>
    document.addEventListener('DOMContentLoaded', async function () {
      if (!AuthLab.requireToken()) return;

      document.getElementById('logout').addEventListener('click', function (e) {
        e.preventDefault();
        AuthLab.clearSession();
        window.location.href = '/signIn';
      });

      try {
        var res = await fetch('/api/users/me', { headers: AuthLab.authHeaders() });
        await AuthLab.handleAuthResponse(res);
        var me = await res.json();
        document.getElementById('welcome').textContent =
          'Bienvenido, ' + (me.name || '') + ' ' + (me.lastName || '');
        var ul = document.getElementById('summary');
        ul.innerHTML =
          '<li class="collection-item"><strong>Email</strong>: ' +
          me.email +
          '</li>' +
          '<li class="collection-item"><strong>Teléfono</strong>: ' +
          me.phoneNumber +
          '</li>' +
          '<li class="collection-item"><strong>Roles</strong>: ' +
          (me.roles || []).join(', ') +
          '</li>';
      } catch (e) {}
    });
  </script>
</body>
</html>
